{
  "permissions": {
    "allow": [
      "Read:*",
      "Write:*",
      "Edit:*",
      "Glob:*",
      "Grep:*",
      "Bash:git:*",
      "Bash:npm:*",
      "Bash:npx:*",
      "Bash:node:*",
      "Bash:ls:*",
      "WebFetch",
      "WebSearch",
      "NotebookEdit"
    ],
    "deny": [
      "Read:.env*",
      "Bash:sudo:*",
      "Bash:rm -rf:*",
      "Write:.env*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Writing file — verify no secrets in content'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File edited successfully'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}